-- 4. CREATE TABS
-- ====================================================================
local MainTab = Window:CreateTab("Farming", "zap")
local BackpacksTab = Window:CreateTab("Backpacks", "briefcase")
local UpgradesTab = Window:CreateTab("Upgrades", "trending-up")

-- ====================================================================
-- 5. FARMING TAB ELEMENTS
-- ====================================================================
MainTab:CreateSection("Automation")

MainTab:CreateToggle({
   Name = "Auto Hack PC",
   CurrentValue = false,
   Flag = "AutoHackPC",
   Callback = function(Value)
       AutoHackPC = Value
   end,
})

MainTab:CreateToggle({
   Name = "Auto Break Walls",
   CurrentValue = false,
   Flag = "AutoBreakWalls",
   Callback = function(Value)
       AutoBreakWalls = Value
   end,
})

MainTab:CreateToggle({
   Name = "Auto Rebirth",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
       AutoRebirth = Value
   end,
})

MainTab:CreateInput({
   Name = "Wall Break Delay",
   CurrentValue = "0.1",
   PlaceholderText = "Enter delay (0 = instant)",
   RemoveTextAfterFocusLost = false,
   Flag = "BreakWallDelay",
   Callback = function(Text)
       local num = tonumber(Text)
       if num then BreakWallDelay = num end
   end,
})

-- ====================================================================
-- 6. BACKPACKS TAB ELEMENTS
-- ====================================================================
BackpacksTab:CreateSection("Auto Progression")

BackpacksTab:CreateToggle({
   Name = "Auto Buy & Equip Best Backpack",
   CurrentValue = false,
   Flag = "AutoBuyBackpacks",
   Callback = function(Value)
       AutoBuyBackpacks = Value
   end,
})

