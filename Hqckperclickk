UpgradesTab:CreateSection("Auto Buy Upgrades")

UpgradesTab:CreateToggle({
   Name = "Auto Upgrade Hack Rate",
   CurrentValue = false,
   Flag = "AutoUpgradeHack",
   Callback = function(Value)
       AutoUpgradeHack = Value
   end,
})

UpgradesTab:CreateToggle({
   Name = "Auto Upgrade Training Rate",
   CurrentValue = false,
   Flag = "AutoUpgradeTraining",
   Callback = function(Value)
       AutoUpgradeTraining = Value
   end,
})

