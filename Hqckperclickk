local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- ====================================================================
-- 2. CORE GAME FUNCTIONALITY
-- ====================================================================
local AutoHackPC = false
local AutoBreakWalls = false
local BreakWallDelay = 0.1
local AutoRebirth = false

local AutoUpgradeHack = false
local AutoUpgradeTraining = false

local AutoBuyBackpacks = false

-- Backpack tier progression list ordered according to game files
local BackpackTiers = {
    "Normal", "AI", "Blue", "Cyber", "Diamond", "Emerald", 
    "Glitch", "Gold", "Green", "Neon", "Purple", "Quantum", 
    "RGB", "Rainbow", "Red", "Ruby"
}

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local KnitServices = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("_Index")["sleitnick_knit@1.7.0"].knit.Services

-- Remote References
local KickServiceRemote = KnitServices:WaitForChild("KickService"):WaitForChild("RF"):WaitForChild("AddKick")
local HitWallRemote = KnitServices:WaitForChild("BreakWallService"):WaitForChild("RF"):WaitForChild("HitWall")
local RebirthRemote = KnitServices:WaitForChild("RebirthService"):WaitForChild("RF"):WaitForChild("Rebirth")
local UpgradeRemote = KnitServices:WaitForChild("UpgradesService"):WaitForChild("RF"):WaitForChild("Purchase")

-- Backpack Remotes
local UnlockBackpackRemote = KnitServices:WaitForChild("BackpackService"):WaitForChild("RF"):WaitForChild("UnlockBackpack")
local EquipBackpackRemote = KnitServices:WaitForChild("BackpackService"):WaitForChild("RF"):WaitForChild("EquipBackpack")

-- Background Threads
task.spawn(function()
    while true do
        if AutoHackPC then
            pcall(function() KickServiceRemote:InvokeServer(nil) end)
        end
        task.wait(0.1)
    end
end)

task.spawn(function()
    while true do
        if AutoBreakWalls then
            pcall(function() HitWallRemote:InvokeServer() end)
        end
        if BreakWallDelay > 0 then
            task.wait(BreakWallDelay)
        else
            task.wait()
        end
    end
end)

task.spawn(function()
    while true do
        if AutoRebirth then
            pcall(function() RebirthRemote:InvokeServer() end)
        end
        task.wait(1.0)
    end
end)

task.spawn(function()
    while true do
        if AutoUpgradeHack then
            pcall(function() UpgradeRemote:InvokeServer("Hack Rate") end)
        end
        if AutoUpgradeTraining then
            pcall(function() UpgradeRemote:InvokeServer("Training Rate") end)
        end
        task.wait(0.5)
    end
end)

-- Auto Buy & Equip Best Backpack Progression Thread
task.spawn(function()
    while true do
        if AutoBuyBackpacks then
            for _, backpackName in ipairs(BackpackTiers) do
                if not AutoBuyBackpacks then break end
                pcall(function()
                    UnlockBackpackRemote:InvokeServer(backpackName)
                    EquipBackpackRemote:InvokeServer(backpackName)
                end)
            end
        end
        task.wait(2.5)
    end
end)

