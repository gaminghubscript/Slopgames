    "The Last King",
    "Dark Devil"
}

-- Auto Speed Function
local function AutoSpeed()
    if not AddSpeedEvent then return end
    while autoSpeedEnabled and RunService:IsRunning() do
        pcall(function()
            AddSpeedEvent:FireServer()
        end)
        task.wait(0.01)
    end
end

-- Auto Rebirth Function
local function AutoRebirth()
    if not RequestRebirthEvent then return end
    while autoRebirthEnabled and RunService:IsRunning() do
        pcall(function()
            RequestRebirthEvent:InvokeServer()
        end)
        task.wait(0.5)
    end
end

-- Auto Win utilizing direct CFrame teleportation
local function AutoWin()
    while autoWinEnabled and RunService:IsRunning() do
        pcall(function()
            if character and character:FindFirstChild("HumanoidRootPart") then
                local hrp = character.HumanoidRootPart
                
                -- Instant movement setup to avoid falling / delays
                hrp.CFrame = targetCFrame + Vector3.new(0, 2, 0)
                
                -- Fire the purchase event immediately upon teleporting (if enabled)
                if autoBuyAuraEnabled and CarActionEvent then
                    for _, aura in pairs(auraNames) do
                        pcall(function()
                            CarActionEvent:FireServer("BuyWins", aura)
                        end)
                        task.wait(0.02)
                    end
                end
            end
        end)
        task.wait(0.3) -- Fast loop for instant wins
    end
end

