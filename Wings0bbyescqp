end)

-- Event References
local AddSpeedEvent = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("AddSpeed")
local CarActionEvent = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("CarAction")
local RequestRebirthEvent = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("RequestRebirth")

-- Target Win Coordinates
local targetCFrame = CFrame.new(21163.2148, 59.604248, -772.093079, -1, 0, 0, 0, 1, 0, 0, 0, -1)

-- Comprehensive Aura List (From Screenshots & Logs)
local auraNames = {
    "Flame Aura",
    "Disco Aura",
    "Sparkle Aura",
    "Purple Shine Aura",
    "Rich Aura",
    "Lightning Aura",
    "Devil Aura",
    "Toxic Aura",
